{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-cli",
      "type": "shell",
      "command": "go",
      "args": [
        "build",
        "-o",
        "mini-http.exe",
        "main.go"
      ],
      "group": "build",
      "problemMatcher": ["$go"]
    },
    {
      "label": "tidy",
      "type": "shell",
      "command": "go",
      "args": ["mod", "tidy"],
      "group": "build",
      "problemMatcher": ["$go"]
    }
  ]
}